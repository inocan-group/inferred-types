{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ES2022",
        "moduleResolution": "Bundler",
        "paths": {
            "inferred-types/types": [
                "../types/src/index.ts"
            ],
            "inferred-types/constants": [
                "../constants/src/index.ts"
            ],
            "inferred-types/runtime": [
                "./src/index.ts"
            ],
            "runtime/*": [
                "./src/*"
            ],
            "constants/*": [
                "../constants/src/*"
            ],
            "types/*": [
                "../types/src/*"
            ]
        },
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "preserveConstEnums": true,
        "strictNullChecks": true,
        "stripInternal": false,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
