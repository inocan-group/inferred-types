{
    "name": "@inferred-types/inferred-types",
    "private": true,
    "type": "module",
    "main": "dist/index.cjs",
    "module": "dist/index.mjs",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "scripts": {
        "nuke": "rm -rf node_modules",
        "build": "tsdown",
        "test": "vitest run",
        "lint": "eslint src --fix",
        "circular": "npx madge --circular src/",
        "watch": "run-p watch:*",
        "watch:build": "tsdown --watch",
        "watch:test": "vitest"
    },
    "dependencies": {
        "@inferred-types/constants": "workspace:*",
        "@inferred-types/types": "workspace:*",
        "@inferred-types/runtime": "workspace:*"
    },
    "devDependencies": {
        "@type-challenges/utils": "catalog:",
        "npm-run-all": "catalog:",
        "tsdown": "catalog:"
    }
}
