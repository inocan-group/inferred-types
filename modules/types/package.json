{
    "name": "@inferred-types/types",
    "private": true,
    "type":"module",
    "main": "dist/index.mjs",
    "types": "dist/index.d.mts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "scripts": {
        "nuke": "rm -rf node_modules",
        "build": "tsdown",
        "circular": "npx madge --circular --warning --exclude '^\\.\\./\\.\\./' --ts-config tsconfig.tsdown.json src/**/*.ts",
        "circular:summary": "FORCE_COLOR=1 npx madge --circular --summary --exclude '^\\.\\./\\.\\./' --ts-config tsconfig.tsdown.json src/**/*.ts | grep -vE '^\\x1b\\[[0-9;]*m\\x1b\\[[0-9;]*m[01]\\x1b'",
        "test": "vitest run",
        "lint": "eslint src",
        "deps": "npx typed deps",
        "watch": "run-p watch:*",
        "watch:build": "tsdown --watch",
        "watch:test": "vitest",
        "source": "echo 'Types Module' && npx typed source"
    },
    "dependencies": {
        "@inferred-types/constants": "workspace:*"
    },
    "devDependencies": {
        "@type-challenges/utils": "catalog:",
        "@types/luxon": "catalog:",
        "@typescript-eslint/eslint-plugin": "catalog:",
        "@typescript-eslint/parser": "catalog:",
        "eslint": "catalog:",
        "eslint-plugin-format": "catalog:",
        "eslint-plugin-promise": "catalog:",
        "npm-run-all": "catalog:",
        "tsdown": "catalog:",
        "typecheck": "catalog:",
        "typed-tester": "catalog:",
        "typescript": "catalog:",
        "typescript-eslint": "catalog:",
        "vitest": "catalog:",
        "vue": "catalog:"
    }
}
