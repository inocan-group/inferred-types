{
  "compilerOptions": {
    "noEmit": true,
    "module": "ES2022",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "incremental": true,
    "noUnusedLocals": false,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "tsBuildInfoFile": ".tsbuildinfo",
    "strictNullChecks": true,
    "esModuleInterop": true,
    "rootDir": "..",
    "outDir": "../../dist/none",
    "paths": {
      "transpiled/runtime": ["../modules/runtime/dist/index.d.mts"],
      "transpiled/types": ["../modules/types/dist/index.d.mts"],
      "transpiled/constants": ["../modules/constants/dist/index.d.mts"],
      "transpiled": ["../modules/inferred-types/dist/index.d.mts"]
    }
  },
  "include": [
    ".",
    "**/package.json",
    "../modules",
    ".claude/hooks"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
